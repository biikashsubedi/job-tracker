generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Application {
  id             String    @id @default(cuid())
  position       String
  company        String
  roleType       String    // Full-time | Part-time | Contract | Freelance | Internship
  status         String    // see STATUSES in src/lib/constants.ts
  workMode       String    // Remote | Hybrid | On-site | N/A
  techStack      String?   // comma-separated, e.g. "Python, TensorFlow, SQL"
  skillMatch     Int?      // 0–100
  interviewRound String?   // None | Round 1 | Round 2 | Round 3 | Final Round | Offer Stage
  salaryMin      Int?
  salaryMax      Int?
  dateApplied    DateTime?
  platform       String    // LinkedIn | Company Site | JobStreet | Indeed | Kalibrr | Referral | HR Portal | Other
  deadline       DateTime?
  notes          String?
  jobUrl         String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  documents      Document[]
  statusHistory  StatusEvent[]
}

model Document {
  id            String      @id @default(cuid())
  filename      String
  storedPath    String
  kind          String      // Resume | Cover Letter | Job Description | Other
  isActive      Boolean     @default(true) // false = superseded by a newer version
  uploadedAt    DateTime    @default(now())
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  applicationId String

  @@index([applicationId, kind, isActive])
}

model LookupOption {
  id        String    @id @default(cuid())
  type      String // STATUS | PLATFORM | WORK_MODE | ROLE_TYPE | INTERVIEW_ROUND
  label     String
  color     String // blue|amber|purple|green|slate|red|emerald|sky|orange|pink|indigo|teal|gray
  group     String? // STATUS only: Applied | Interviewing | Assessment | Offer | Closed
  sortOrder Int
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([type, label])
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String?
  passwordHash String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  failedLogins Int       @default(0)
  lockedUntil  DateTime?
}

model StatusEvent {
  id            String      @id @default(cuid())
  fromStatus    String?
  toStatus      String
  changedAt     DateTime    @default(now())
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  applicationId String
}
