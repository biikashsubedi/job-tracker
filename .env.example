# Copy to .env and fill in real values. Never commit .env.

# Prisma database connection (SQLite for local dev)
DATABASE_URL="file:./dev.db"

# Auth.js (NextAuth v5)
# Generate a strong secret with: npx auth secret   (or: openssl rand -base64 33)
AUTH_SECRET="replace-with-a-long-random-secret"

# Trust the host header (needed for self-hosted / non-Vercel deploys)
AUTH_TRUST_HOST=true

# In production, set the canonical URL of the app:
# AUTH_URL="https://your-domain.example"
